       <div class="interest-item"><span>🤖</span> Agentic AI</div>
       <div class="interest-item"><span>⛓️</span> Blockchain</div>
       <div class="interest-item"><span>🎨</span> Creative Coding</div>
       <div class="interest-item"><span>🌐</span> Web Design</div>
       <div class="interest-item"><span>🏔️</span> Dehradun Life</div>
     </div>
   </div>
 
   <div class="info-card">
     <div class="info-card-header">
       <div class="info-card-icon">✍️</div>
       <div><div class="info-card-title">Writing & Blog</div><div class="info-card-sub">Thoughts on tech, finance & life</div></div>
     </div>
     <div class="skill-pills">
       <span class="skill-pill">Finance × Tech</span><span class="skill-pill">AI Explorations</span>
       <span class="skill-pill">Dev Logs</span><span class="skill-pill">Web3 Insights</span>
     </div>
   </div>
 </div>
 
 
 
 <p class="footer-tag">Made with 🫧 liquid glass · <a href="https://prashantbhatt.net" target="_blank" rel="noopener">Prashant Bhatt</a></p>
 
   </main>
 </div>
 
 <script>
   const trigger = document.getElementById('themeTrigger');
   const panel   = document.getElementById('themePanel');
   const body    = document.body;
   const options = document.querySelectorAll('.theme-option');
 
   trigger.addEventListener('click', (e) => {
     e.stopPropagation();
     const isOpen = panel.classList.toggle('open');
     trigger.setAttribute('aria-expanded', isOpen);
   });
   document.addEventListener('click', () => {
     panel.classList.remove('open');
     trigger.setAttribute('aria-expanded', false);
   });
   panel.addEventListener('click', (e) => e.stopPropagation());
   options.forEach(btn => {
     btn.addEventListener('click', () => {
       const t = btn.dataset.themeVal;
       body.setAttribute('data-theme', t);
       options.forEach(o => o.classList.remove('active'));
       btn.classList.add('active');
       setTimeout(() => {
         panel.classList.remove('open');
         trigger.setAttribute('aria-expanded', false);
       }, 280);
     });
   });
   document.addEventListener('keydown', (e) => {
     if (e.key === 'Escape') { panel.classList.remove('open'); trigger.setAttribute('aria-expanded', false); }
   });
 </script>
 
 </body>
 </html>
