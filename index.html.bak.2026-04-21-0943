 <script>
   const trigger = document.getElementById('themeTrigger');
   const panel   = document.getElementById('themePanel');
   const body    = document.body;
   const options = document.querySelectorAll('.theme-option');
 
   trigger.addEventListener('click', (e) => {
     e.stopPropagation();
     const isOpen = panel.classList.toggle('open');
     trigger.setAttribute('aria-expanded', isOpen);
   });
   document.addEventListener('click', () => {
     panel.classList.remove('open');
     trigger.setAttribute('aria-expanded', false);
   });
   panel.addEventListener('click', (e) => e.stopPropagation());
   options.forEach(btn => {
     btn.addEventListener('click', () => {
       const t = btn.dataset.themeVal;
       body.setAttribute('data-theme', t);
       localStorage.setItem('pb-theme', t);
       options.forEach(o => o.classList.remove('active'));
       btn.classList.add('active');
       setTimeout(() => {
         panel.classList.remove('open');
         trigger.setAttribute('aria-expanded', false);
       }, 280);
     });
   });
   document.addEventListener('keydown', (e) => {
     if (e.key === 'Escape') { panel.classList.remove('open'); trigger.setAttribute('aria-expanded', false); }
   });

   /* ── Restore saved theme ── */
   const savedTheme = localStorage.getItem('pb-theme');
   if (savedTheme) {
     body.setAttribute('data-theme', savedTheme);
     options.forEach(o => o.classList.toggle('active', o.dataset.themeVal === savedTheme));
   }

   /* ── Skill Tab Switcher ── */
   function switchTab(btn, panelId) {
     const card = btn.closest('.info-card');
     card.querySelectorAll('.skill-tab').forEach(t => t.classList.remove('active'));
     card.querySelectorAll('.skill-tab-panel').forEach(p => p.classList.remove('active'));
     btn.classList.add('active');
     const panel = document.getElementById(panelId);
     panel.classList.add('active');
     // Animate bars in newly shown panel
     panel.querySelectorAll('.skill-bar-fill').forEach(bar => {
       bar.style.width = '0';
       requestAnimationFrame(() => {
         setTimeout(() => { bar.style.width = bar.dataset.width + '%'; }, 50);
       });
     });
   }

   /* ── Skill Bar Intersection Observer ── */
   const observer = new IntersectionObserver((entries) => {
     entries.forEach(entry => {
       if (entry.isIntersecting) {
         entry.target.querySelectorAll('.skill-tab-panel.active .skill-bar-fill').forEach(bar => {
           bar.style.width = bar.dataset.width + '%';
         });
         observer.unobserve(entry.target);
       }
     });
   }, { threshold: 0.3 });

   document.querySelectorAll('.info-card').forEach(card => observer.observe(card));

   /* ── Banking Counter Animation ── */
   const counterEl = document.getElementById('banking-counter');
   const counterObserver = new IntersectionObserver((entries) => {
     entries.forEach(entry => {
       if (entry.isIntersecting) {
         const target = 12;
         const duration = 1800;
         const startTime = performance.now();
         function easeOutExpo(t) { return t === 1 ? 1 : 1 - Math.pow(2, -10 * t); }
         function tick(now) {
           const elapsed = now - startTime;
           const progress = Math.min(elapsed / duration, 1);
           const eased = easeOutExpo(progress);
           counterEl.textContent = Math.floor(eased * target);
           if (progress < 1) {
             requestAnimationFrame(tick);
           } else {
             counterEl.textContent = target;
           }
         }
         requestAnimationFrame(tick);
         counterObserver.unobserve(entry.target);
       }
     });
   }, { threshold: 0.6 });
   counterObserver.observe(counterEl.closest('.stat-card'));

   /* ── Stat Card Ripple ── */
   document.querySelectorAll('.stat-card').forEach(card => {
     card.addEventListener('click', e => {
       const r = document.createElement('span');
       r.className = 'ripple';
       const size = Math.max(card.offsetWidth, card.offsetHeight);
       r.style.cssText = `width:${size}px;height:${size}px;left:${e.offsetX - size/2}px;top:${e.offsetY - size/2}px;`;
       card.appendChild(r);
       setTimeout(() => r.remove(), 700);
     });
   });

   /* ── LIVE MUSIC PLAYER ── */
   (function() {
     const tracks = [
       {
         url: 'track1.mp3',
         name: 'Chill Lofi Study Beat',
         artist: 'Pixabay · Lo-fi',
         emoji: '🎵'
       },
       {
         url: 'track2.mp3',
         name: 'Deep Focus Flow',
         artist: 'Pixabay · Ambient',
         emoji: '🎧'
       },
       {
         url: 'track3.mp3',
         name: 'Mountain Morning Jazz',
         artist: 'Pixabay · Jazz',
         emoji: '🏔️'
       }
     ];

     let current = 0;
     const audio      = document.getElementById('vibeAudio');
     const player     = document.getElementById('vibePlayer');
     const playBtn    = document.getElementById('vibePlayBtn');
     const disc       = document.getElementById('vibeDisc');
     const trackName  = document.getElementById('vibeTrackName');
     const artist     = document.getElementById('vibeArtist');
     const fill       = document.getElementById('vibeProgressFill');
     const trackEl    = document.getElementById('vibeProgressTrack');
     const timeEl     = document.getElementById('vibeTime');
     const trackItems = document.querySelectorAll('.vibe-track-item');

     function fmt(s) {
       if (isNaN(s)) return '0:00';
       const m = Math.floor(s / 60);
       const sec = Math.floor(s % 60).toString().padStart(2,'0');
       return m + ':' + sec;
     }

     function loadTrack(idx, autoplay) {
       current = idx;
       const t = tracks[idx];
       audio.src = t.url;
       audio.load();
       disc.textContent = t.emoji;
       trackName.textContent = t.name;
       artist.textContent = t.artist;
       fill.style.width = '0%';
       timeEl.textContent = '0:00 / 0:00';
       trackItems.forEach((el, i) => el.classList.toggle('active', i === idx));
       if (autoplay) audio.play().catch(() => {});
     }

     function togglePlay() {
       if (audio.paused) {
         if (!audio.src) loadTrack(0, true);
         else audio.play().catch(() => {});
       } else {
         audio.pause();
       }
     }

     playBtn.addEventListener('click', togglePlay);

     audio.addEventListener('play', () => player.classList.add('playing'));
     audio.addEventListener('pause', () => player.classList.remove('playing'));
     audio.addEventListener('ended', () => {
       const next = (current + 1) % tracks.length;
       loadTrack(next, true);
     });

     audio.addEventListener('timeupdate', () => {
       if (!audio.duration) return;
       const pct = (audio.currentTime / audio.duration) * 100;
       fill.style.width = pct + '%';
       timeEl.textContent = fmt(audio.currentTime) + ' / ' + fmt(audio.duration);
     });

     /* Click on progress bar to seek */
     trackEl.addEventListener('click', e => {
       if (!audio.duration) return;
       const rect = trackEl.getBoundingClientRect();
       const ratio = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
       audio.currentTime = ratio * audio.duration;
     });

     /* Track list clicks */
     trackItems.forEach((el, i) => {
       el.addEventListener('click', () => {
         if (i === current) { togglePlay(); }
         else { loadTrack(i, true); }
       });
     });

     /* Load first track info without auto-playing */
     loadTrack(0, false);
   })();

   /* ── Info Card Magnetic Tilt ── */
   document.querySelectorAll('.info-card').forEach(card => {
     card.addEventListener('mousemove', e => {
       const rect = card.getBoundingClientRect();
       const cx = rect.left + rect.width / 2;
       const cy = rect.top + rect.height / 2;
       const dx = (e.clientX - cx) / (rect.width / 2);
       const dy = (e.clientY - cy) / (rect.height / 2);
       card.style.transform = `translateY(-4px) rotateX(${-dy * 3}deg) rotateY(${dx * 3}deg)`;
     });
     card.addEventListener('mouseleave', () => {
       card.style.transform = '';
     });
   });
 </script>

